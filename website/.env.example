# Copy to .env.local and fill in. None are required for the site to run;
# without them, the contact form logs submissions instead of emailing.

# ── Contact form email delivery (Resend) ───────────────────────────
# Create a key at https://resend.com. Without a verified domain you can send
# from onboarding@resend.dev for testing; verify a domain for production.
CONTACT_PROVIDER_API_KEY=
CONTACT_TO_EMAIL=business.jakhar@gmail.com
CONTACT_FROM_EMAIL="Rahul Jakhar <onboarding@resend.dev>"

# ── Site ───────────────────────────────────────────────────────────
# Production origin — used for canonical URLs, Open Graph, and sitemap.
# Leave unset in dev (defaults to http://localhost:3000).
NEXT_PUBLIC_SITE_URL=
